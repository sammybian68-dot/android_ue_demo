<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/phone_pop_up_1"
    android:clickable="true"
    android:focusable="true"
    android:contentDescription="@string/outgoing_call_mini_bg_desc">

    <!-- Phone number: (52, 57), fontSize 30, #FBFFFE -->
    <TextView
        android:id="@+id/tv_mini_phone_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/outgoing_mini_number_text_size"
        android:textColor="@color/dark_primary_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="@dimen/outgoing_mini_number_margin_start"
        android:layout_marginTop="@dimen/outgoing_mini_number_margin_top" />

    <!-- Status: (52, 100), fontSize 26, #80FBFFFE -->
    <TextView
        android:id="@+id/tv_mini_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/outgoing_call_dialing"
        android:textSize="@dimen/outgoing_mini_status_text_size"
        android:textColor="@color/dark_secondary_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="@dimen/outgoing_mini_status_margin_start"
        android:layout_marginTop="@dimen/outgoing_mini_status_margin_top" />

    <!-- Mute button: (516, 52), 80×80 -->
    <ImageView
        android:id="@+id/btn_mini_mute"
        android:layout_width="@dimen/outgoing_mini_btn_size"
        android:layout_height="@dimen/outgoing_mini_btn_size"
        android:src="@drawable/bt_btn_mute_n"
        android:scaleType="fitCenter"
        android:contentDescription="@string/outgoing_call_mute_btn_desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="@dimen/outgoing_mini_mute_margin_start"
        android:layout_marginTop="@dimen/outgoing_mini_mute_margin_top" />

    <!-- Hang up button: (628, 52), 80×80 -->
    <ImageView
        android:id="@+id/btn_mini_hang_up"
        android:layout_width="@dimen/outgoing_mini_btn_size"
        android:layout_height="@dimen/outgoing_mini_btn_size"
        android:src="@drawable/bt_btn_hang_up_n"
        android:scaleType="fitCenter"
        android:contentDescription="@string/outgoing_call_hang_up_btn_desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="@dimen/outgoing_mini_hangup_margin_start"
        android:layout_marginTop="@dimen/outgoing_mini_hangup_margin_top" />

</androidx.constraintlayout.widget.ConstraintLayout>
