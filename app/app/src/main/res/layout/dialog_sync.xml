<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/sync_dialog_width"
    android:layout_height="@dimen/sync_dialog_height"
    android:background="@drawable/details_popup_1">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="@dimen/sync_content_width"
        android:layout_height="@dimen/sync_content_height"
        android:layout_marginStart="@dimen/sync_content_padding_start"
        android:layout_marginTop="@dimen/sync_content_padding_top"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Title -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/sync_title_margin_bottom"
                android:gravity="center"
                android:text="@string/sync_dialog_title"
                android:textColor="@color/dark_primary_text"
                android:textSize="@dimen/sync_title_text_size" />

            <!-- Step label -->
            <TextView
                android:id="@+id/tv_steps_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="13px"
                android:text="@string/sync_steps_label"
                android:textColor="@color/dark_primary_text"
                android:textSize="@dimen/sync_step_text_size" />

            <!-- Step 1 -->
            <TextView
                android:id="@+id/tv_step_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="13px"
                android:text="@string/sync_step_1"
                android:textColor="@color/dark_primary_text"
                android:textSize="@dimen/sync_step_text_size" />

            <!-- Step 2 -->
            <TextView
                android:id="@+id/tv_step_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="13px"
                android:text="@string/sync_step_2"
                android:textColor="@color/dark_primary_text"
                android:textSize="@dimen/sync_step_text_size" />

            <!-- Step 3 -->
            <TextView
                android:id="@+id/tv_step_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="13px"
                android:text="@string/sync_step_3"
                android:textColor="@color/dark_primary_text"
                android:textSize="@dimen/sync_step_text_size" />

            <!-- Auth hint -->
            <TextView
                android:id="@+id/tv_auth_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="13px"
                android:text="@string/sync_auth_hint"
                android:textColor="@color/dark_secondary_text"
                android:textSize="@dimen/sync_hint_text_size" />

            <!-- Brand intro -->
            <TextView
                android:id="@+id/tv_brand_intro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13px"
                android:lineSpacingExtra="13px"
                android:text="@string/sync_brand_intro"
                android:textColor="@color/dark_primary_text"
                android:textSize="@dimen/sync_step_text_size" />

            <!-- Brand list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_brands"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sync_brand_gap"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <!-- Disclaimer -->
            <TextView
                android:id="@+id/tv_disclaimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sync_disclaimer_margin_top"
                android:lineSpacingExtra="12px"
                android:textColor="@color/dark_secondary_text"
                android:textSize="@dimen/sync_disclaimer_text_size" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
