<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/android_bg">

    <!-- Group: full-screen elements visibility -->
    <androidx.constraintlayout.widget.Group
        android:id="@+id/group_full_screen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="btn_minimize,tv_phone_number,tv_call_time,btn_switch_phone,btn_mute_full,btn_hang_up_full,btn_keyboard,tv_label_switch,tv_label_mute,tv_label_hang_up,tv_label_keyboard" />

    <!-- ==================== Full screen: top area ==================== -->

    <!-- Minimize button: app(48, 56), 80×80 -->
    <ImageView
        android:id="@+id/btn_minimize"
        android:layout_width="@dimen/in_call_full_minimize_size"
        android:layout_height="@dimen/in_call_full_minimize_size"
        android:src="@drawable/bt_btn_lessen_n"
        android:scaleType="fitCenter"
        android:contentDescription="@string/in_call_minimize_desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="@dimen/in_call_full_minimize_start"
        android:layout_marginTop="@dimen/in_call_full_minimize_top" />

    <!-- Phone number: centered, marginTop 293, 36px -->
    <TextView
        android:id="@+id/tv_phone_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/in_call_full_number_text_size"
        android:textColor="@color/dark_primary_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="@dimen/in_call_full_number_top" />

    <!-- Call time: centered, marginTop 369, 30px, 50% alpha -->
    <TextView
        android:id="@+id/tv_call_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/in_call_full_time_text_size"
        android:textColor="@color/dark_secondary_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="@dimen/in_call_full_time_top" />

    <!-- ==================== Full screen: bottom action buttons ==================== -->

    <!-- Switch to phone: app(200, 704), 160×96 -->
    <ImageView
        android:id="@+id/btn_switch_phone"
        android:layout_width="@dimen/in_call_full_btn_width"
        android:layout_height="@dimen/in_call_full_btn_height"
        android:src="@drawable/keyboard_btn_number_phone_n"
        android:scaleType="fitCenter"
        android:contentDescription="@string/in_call_switch_btn_desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="@dimen/in_call_full_btn_phone_start"
        android:layout_marginTop="@dimen/in_call_full_btn_top" />

    <!-- Mute: app(440, 704), 160×96 -->
    <ImageView
        android:id="@+id/btn_mute_full"
        android:layout_width="@dimen/in_call_full_btn_width"
        android:layout_height="@dimen/in_call_full_btn_height"
        android:src="@drawable/keyboard_btn_number_mute_n"
        android:scaleType="fitCenter"
        android:contentDescription="@string/in_call_mute_btn_desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="@dimen/in_call_full_btn_mute_start"
        android:layout_marginTop="@dimen/in_call_full_btn_top" />

    <!-- Hang up: app(680, 704), 160×96 -->
    <ImageView
        android:id="@+id/btn_hang_up_full"
        android:layout_width="@dimen/in_call_full_btn_width"
        android:layout_height="@dimen/in_call_full_btn_height"
        android:src="@drawable/keyboard_btn_number_hang_up_n"
        android:scaleType="fitCenter"
        android:contentDescription="@string/in_call_hang_up_btn_desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="@dimen/in_call_full_btn_hangup_start"
        android:layout_marginTop="@dimen/in_call_full_btn_top" />

    <!-- Keyboard: app(920, 704), 160×96 -->
    <ImageView
        android:id="@+id/btn_keyboard"
        android:layout_width="@dimen/in_call_full_btn_width"
        android:layout_height="@dimen/in_call_full_btn_height"
        android:src="@drawable/keyboard_btn_number_keyboard_n"
        android:scaleType="fitCenter"
        android:contentDescription="@string/in_call_keyboard_btn_desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="@dimen/in_call_full_btn_keyboard_start"
        android:layout_marginTop="@dimen/in_call_full_btn_top" />

    <!-- ==================== Full screen: button labels ==================== -->

    <TextView
        android:id="@+id/tv_label_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/in_call_switch_phone"
        android:textSize="@dimen/in_call_full_label_text_size"
        android:textColor="@color/dark_secondary_text"
        app:layout_constraintStart_toStartOf="@id/btn_switch_phone"
        app:layout_constraintEnd_toEndOf="@id/btn_switch_phone"
        app:layout_constraintTop_toBottomOf="@id/btn_switch_phone"
        android:layout_marginTop="@dimen/in_call_full_label_gap" />

    <TextView
        android:id="@+id/tv_label_mute"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/in_call_mute"
        android:textSize="@dimen/in_call_full_label_text_size"
        android:textColor="@color/dark_secondary_text"
        app:layout_constraintStart_toStartOf="@id/btn_mute_full"
        app:layout_constraintEnd_toEndOf="@id/btn_mute_full"
        app:layout_constraintTop_toBottomOf="@id/btn_mute_full"
        android:layout_marginTop="@dimen/in_call_full_label_gap" />

    <TextView
        android:id="@+id/tv_label_hang_up"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/in_call_hang_up"
        android:textSize="@dimen/in_call_full_label_text_size"
        android:textColor="@color/dark_secondary_text"
        app:layout_constraintStart_toStartOf="@id/btn_hang_up_full"
        app:layout_constraintEnd_toEndOf="@id/btn_hang_up_full"
        app:layout_constraintTop_toBottomOf="@id/btn_hang_up_full"
        android:layout_marginTop="@dimen/in_call_full_label_gap" />

    <TextView
        android:id="@+id/tv_label_keyboard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/in_call_keyboard"
        android:textSize="@dimen/in_call_full_label_text_size"
        android:textColor="@color/dark_secondary_text"
        app:layout_constraintStart_toStartOf="@id/btn_keyboard"
        app:layout_constraintEnd_toEndOf="@id/btn_keyboard"
        app:layout_constraintTop_toBottomOf="@id/btn_keyboard"
        android:layout_marginTop="@dimen/in_call_full_label_gap" />

    <!-- ==================== DTMF keyboard overlay (hidden by default) ==================== -->
    <include
        android:id="@+id/layout_dtmf"
        layout="@layout/layout_in_call_dtmf"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- ==================== Mini window (hidden by default) ==================== -->
    <include
        android:id="@+id/layout_mini"
        layout="@layout/layout_in_call_mini"
        android:layout_width="@dimen/in_call_mini_width"
        android:layout_height="@dimen/in_call_mini_height"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="@dimen/in_call_mini_start"
        android:layout_marginTop="@dimen/in_call_mini_top" />

    <!-- ==================== Top status bar (hidden by default) ==================== -->
    <include
        android:id="@+id/layout_status_bar"
        layout="@layout/layout_call_status_bar"
        android:layout_width="@dimen/in_call_status_bar_width"
        android:layout_height="@dimen/in_call_status_bar_height"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ==================== Switch dialog overlay (hidden by default) ==================== -->
    <View
        android:id="@+id/view_dialog_mask"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/home_bg_mask"
        android:visibility="gone" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_switch_dialog"
        android:layout_width="@dimen/in_call_dialog_width"
        android:layout_height="@dimen/in_call_dialog_height"
        android:background="@color/popup_bg"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/in_call_switch_dialog_title"
            android:textSize="@dimen/in_call_dialog_text_size"
            android:textColor="@color/dark_primary_text"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="@dimen/in_call_dialog_title_top" />

        <TextView
            android:id="@+id/tv_dialog_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/in_call_switch_dialog_message"
            android:textSize="@dimen/in_call_dialog_text_size"
            android:textColor="@color/dark_primary_text"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="@dimen/in_call_dialog_msg_top" />

        <TextView
            android:id="@+id/btn_dialog_cancel"
            android:layout_width="@dimen/in_call_dialog_btn_width"
            android:layout_height="@dimen/in_call_dialog_btn_height"
            android:text="@string/in_call_switch_dialog_cancel"
            android:textSize="@dimen/in_call_dialog_text_size"
            android:textColor="@color/dark_primary_text"
            android:gravity="center"
            android:background="@color/in_call_dialog_cancel_bg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="@dimen/in_call_dialog_cancel_start"
            android:layout_marginTop="@dimen/in_call_dialog_btn_top" />

        <TextView
            android:id="@+id/btn_dialog_confirm"
            android:layout_width="@dimen/in_call_dialog_btn_width"
            android:layout_height="@dimen/in_call_dialog_btn_height"
            android:text="@string/in_call_switch_dialog_confirm"
            android:textSize="@dimen/in_call_dialog_text_size"
            android:textColor="@color/dark_primary_text"
            android:gravity="center"
            android:background="@color/in_call_dialog_confirm_bg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="@dimen/in_call_dialog_confirm_start"
            android:layout_marginTop="@dimen/in_call_dialog_btn_top" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
