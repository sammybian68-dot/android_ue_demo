<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- =============== Full-screen mode =============== -->

    <!-- Full-screen dark background -->
    <View
        android:id="@+id/bg_fullscreen"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/android_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Minimize button: app(48, 56, 80×80) -->
    <ImageView
        android:id="@+id/btn_minimize"
        android:layout_width="@dimen/incoming_full_btn_minimize_size"
        android:layout_height="@dimen/incoming_full_btn_minimize_size"
        android:layout_marginStart="@dimen/incoming_full_btn_minimize_start"
        android:layout_marginTop="@dimen/incoming_full_btn_minimize_top"
        android:contentDescription="@string/incoming_call_minimize_desc"
        android:scaleType="fitCenter"
        android:src="@drawable/bt_btn_lessen_n"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Caller name: centered horizontally, top=293 -->
    <TextView
        android:id="@+id/tv_caller_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/incoming_full_caller_name_top"
        android:textColor="@color/dark_primary_text"
        android:textSize="@dimen/incoming_full_caller_name_text_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Phone number: centered horizontally, top=369 -->
    <TextView
        android:id="@+id/tv_phone_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/incoming_full_phone_number_top"
        android:textColor="@color/dark_secondary_text"
        android:textSize="@dimen/incoming_full_text_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Call status "来电中": centered horizontally, top=424 -->
    <TextView
        android:id="@+id/tv_call_status_full"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/incoming_full_status_top"
        android:textColor="@color/dark_secondary_text"
        android:textSize="@dimen/incoming_full_text_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Answer button: app(440, 704, 160×96) -->
    <ImageView
        android:id="@+id/btn_answer_full"
        android:layout_width="@dimen/incoming_full_btn_width"
        android:layout_height="@dimen/incoming_full_btn_height"
        android:layout_marginStart="@dimen/incoming_full_btn_answer_start"
        android:layout_marginTop="@dimen/incoming_full_btn_top"
        android:contentDescription="@string/incoming_call_answer_desc"
        android:scaleType="fitCenter"
        android:src="@drawable/keyboard_btn_number_answer_n"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Hangup button: app(680, 704, 160×96) -->
    <ImageView
        android:id="@+id/btn_hangup_full"
        android:layout_width="@dimen/incoming_full_btn_width"
        android:layout_height="@dimen/incoming_full_btn_height"
        android:layout_marginStart="@dimen/incoming_full_btn_hangup_start"
        android:layout_marginTop="@dimen/incoming_full_btn_top"
        android:contentDescription="@string/incoming_call_hangup_desc"
        android:scaleType="fitCenter"
        android:src="@drawable/keyboard_btn_number_hang_up_n"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- "接听" label: centered under answer button, top=824 -->
    <TextView
        android:id="@+id/tv_answer_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/incoming_full_label_top"
        android:textColor="@color/dark_secondary_text"
        android:textSize="@dimen/incoming_full_text_size"
        app:layout_constraintEnd_toEndOf="@id/btn_answer_full"
        app:layout_constraintStart_toStartOf="@id/btn_answer_full"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- "挂断" label: centered under hangup button, top=824 -->
    <TextView
        android:id="@+id/tv_hangup_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/incoming_full_label_top"
        android:textColor="@color/dark_secondary_text"
        android:textSize="@dimen/incoming_full_text_size"
        app:layout_constraintEnd_toEndOf="@id/btn_hangup_full"
        app:layout_constraintStart_toStartOf="@id/btn_hangup_full"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Group to toggle all full-screen mode views -->
    <androidx.constraintlayout.widget.Group
        android:id="@+id/group_fullscreen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="bg_fullscreen,btn_minimize,tv_caller_name,tv_phone_number,tv_call_status_full,btn_answer_full,btn_hangup_full,tv_answer_label,tv_hangup_label" />

    <!-- =============== Mini window mode (included) =============== -->

    <include
        android:id="@+id/container_mini"
        layout="@layout/layout_incoming_call_mini"
        android:layout_width="@dimen/incoming_mini_width"
        android:layout_height="@dimen/incoming_mini_height"
        android:layout_marginStart="@dimen/incoming_mini_margin_start"
        android:layout_marginTop="@dimen/incoming_mini_margin_top"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
