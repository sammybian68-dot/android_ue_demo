<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/contact_item_height"
    android:background="@drawable/bt_list_bg_selector"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/tv_avatar"
        android:layout_width="@dimen/contact_avatar_size"
        android:layout_height="@dimen/contact_avatar_size"
        android:layout_marginStart="@dimen/contact_avatar_margin_start"
        android:background="@drawable/icon_linkman_bg_1"
        android:gravity="center"
        android:textColor="@color/dark_primary_text"
        android:textSize="@dimen/contact_avatar_text_size"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/contact_name_margin_start"
        android:layout_marginEnd="16px"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/dark_primary_text"
        android:textSize="@dimen/contact_name_text_size"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/tv_avatar"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
