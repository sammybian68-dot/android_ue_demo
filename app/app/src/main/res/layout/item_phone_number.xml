<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/contact_detail_item_height"
    android:layout_marginBottom="@dimen/contact_detail_item_gap"
    android:background="@drawable/bt_list_pop_up_selector"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/iv_call_icon"
        android:layout_width="@dimen/contact_detail_icon_size"
        android:layout_height="@dimen/contact_detail_icon_size"
        android:layout_marginStart="@dimen/contact_detail_icon_margin_start"
        android:contentDescription="@string/contact_detail_call_icon_desc"
        android:src="@drawable/icon_list_phone_1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_phone_number"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/contact_detail_number_margin_start"
        android:layout_marginEnd="24px"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/dark_primary_text"
        android:textSize="@dimen/contact_detail_number_text_size"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
